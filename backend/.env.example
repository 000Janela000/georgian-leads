# Database (SQLite - no changes needed, auto-creates)
DATABASE_URL=sqlite:///./data/leads.db

# ========== OPTIONAL: Data Enrichment ==========
# Clearbit API (Free: 50,000 requests/month)
# Sign up: https://clearbit.com/
CLEARBIT_API_KEY=

# Google Custom Search (Free: 100 queries/day, then $5/1000)
# Set up: https://programmablesearchengine.google.com/
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=

# ========== OPTIONAL: Email Sending ==========
# Gmail example - generate app password here: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# ========== OPTIONAL: WhatsApp via Twilio ==========
# Get from: https://www.twilio.com/
# Sandbox mode available for testing
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+1234567890

# ========== OPTIONAL: WhatsApp via Meta Business API ==========
# Get from: https://developers.facebook.com/docs/whatsapp/
META_WHATSAPP_TOKEN=
META_WHATSAPP_PHONE_ID=
META_WHATSAPP_BUSINESS_ACCOUNT_ID=

# ========== Environment ==========
ENV=development
DEBUG=true
